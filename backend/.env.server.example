# Template only.
# Put real values in backend/.env.server and do not commit that file.

# Postgres container
POSTGRES_DB=letmelens
POSTGRES_USER=letmelens_db
POSTGRES_PASSWORD=

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/letmelens
SPRING_DATASOURCE_USERNAME=letmelens_db
SPRING_DATASOURCE_PASSWORD=

# Mail
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_REQUIRED=true

# Google OAuth
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=

# App settings
APP_FRONTEND_BASE_URL=https://your-domain.com
APP_STORAGE_LOCAL_ROOT_PATH=/var/lib/photo-gallery/storage
SERVER_FORWARD_HEADERS_STRATEGY=framework

# Upload limits (keep Tomcat limits >= multipart limits)
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=15MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=15MB
SERVER_TOMCAT_MAX_HTTP_FORM_POST_SIZE=15MB
SERVER_TOMCAT_MAX_SWALLOW_SIZE=15MB
